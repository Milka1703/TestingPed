# SMTP вашей почты (уточните host/port у IT-отдела для @itmoscow.pro)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_DNS_SERVERS=8.8.8.8,1.1.1.1
SMTP_DNS_TIMEOUT=20000
SMTP_CONNECTION_TIMEOUT=20000
SMTP_GREETING_TIMEOUT=20000
SMTP_SOCKET_TIMEOUT=30000
SMTP_USER=your-email@itmoscow.pro
SMTP_PASS=your-smtp-password-or-app-password
SMTP_FROM=your-email@itmoscow.pro
RESULT_RECIPIENT_EMAIL=seregina_ld@itmoscow.pro
